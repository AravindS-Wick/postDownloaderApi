# ─────────────────────────────────────────────────────────────────────────────
# postDownloaderApi — environment variable reference
# Copy this file to .env and fill in your values.
# .env is git-ignored. This file (.env.example) is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────

# "development" | "production" | "test"
# Controls: dev-only warnings, email sending vs. console logging, etc.
NODE_ENV=development

# Server port (default: 2500)
PORT=2500

# Server bind address (default: 0.0.0.0 — all interfaces)
HOST=0.0.0.0

# Comma-separated list of allowed CORS origins
# e.g. http://localhost:8081,https://yourdomain.com
CORS_ORIGINS=http://localhost:8081

# ── Auth ─────────────────────────────────────────────────────────────────────

# REQUIRED. Secret used to sign JWTs. Use a long random string in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# ── Database driver ───────────────────────────────────────────────────────────

# "sqlite" → better-sqlite3, local file  (default, for local dev)
# "mongo"  → MongoDB Atlas               (for Railway / production)
DB_DRIVER=sqlite

# ── SQLite (DB_DRIVER=sqlite) ─────────────────────────────────────────────────

# Directory where db/app.db is stored.
# Leave unset to use the project root (default for local dev).
# On Railway with a persistent volume, set to the mounted path e.g. /data
# DATA_DIR=/data

# ── MongoDB (DB_DRIVER=mongo) ─────────────────────────────────────────────────

# REQUIRED when DB_DRIVER=mongo.
# Get this from MongoDB Atlas → your cluster → Connect → Drivers.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/social-downloader?retryWrites=true&w=majority

# ── Seed users ────────────────────────────────────────────────────────────────

# Optional JSON array to override default seed users.
# Seed users are created (and marked verified) on startup if they don't exist.
# Useful for Railway where the DB starts empty.
# Default (used when this is unset):
#   admin@test.com / TestPassword123! (role: admin)
#   owner@test.com / TestPassword123! (role: owner)
#   tester@test.com / TestPassword123! (role: tester)
#   user@test.com / TestPassword123! (role: user)
#
# SEED_USERS=[{"email":"admin@yourapp.com","password":"StrongPass1!","role":"admin"}]

# ── Email (nodemailer / Gmail) ────────────────────────────────────────────────

# Gmail address used as the sender for verification & password-reset emails.
GMAIL_USER=your_gmail@gmail.com

# Gmail App Password (NOT your regular Gmail password).
# Generate at: Google Account → Security → 2-Step Verification → App passwords
GMAIL_APP_PASSWORD=your_gmail_app_password

# ── Freemium limits ───────────────────────────────────────────────────────────

# Enable guest (unauthenticated) download limits (default: false)
FREEMIUM_ENABLED=false

# Max downloads allowed per IP before login is required (default: 10)
FREEMIUM_LIMIT=10

# ── yt-dlp / cookies ──────────────────────────────────────────────────────────

# Browser to pull cookies from for age-restricted content
# e.g. "chrome", "firefox". Leave blank to disable.
# COOKIES_FROM_BROWSER=chrome

# Path to a Netscape-format cookies.txt file on disk (for Railway)
# COOKIES_FILE=/data/cookies.txt

# Raw cookie file contents as a string (alternative to COOKIES_FILE on Railway)
# Paste the full content of your cookies.txt here.
# COOKIES_CONTENT=

# ── OAuth (optional — only needed if OAuth login is wired up) ─────────────────

# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=
# INSTAGRAM_REDIRECT_URI=

# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REDIRECT_URI=

# TIKTOK_CLIENT_ID=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=

# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=
# TWITTER_REDIRECT_URI=

# ── Admin / role bootstrap ────────────────────────────────────────────────────

# Email that gets the "owner" role on first startup (optional)
# OWNER_EMAIL=you@yourapp.com

# Comma-separated emails that get the "admin" role on first startup (optional)
# ADMIN_EMAILS=admin1@yourapp.com,admin2@yourapp.com
